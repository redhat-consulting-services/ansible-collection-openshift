---
apiVersion: config.openshift.io/v1
kind: ImageDigestMirrorSet
metadata:
  name: idms-gitops
spec:
  imageDigestMirrors:
    - source: registry.redhat.io/openshift-gitops-1
      mirrors:
{% if registry.repository is not defined or registry.repository == "" %}
        - "{{ registry.url }}/openshift-gitops-1"
{% else %}
        - "{{ registry.url }}/{{ registry.repository }}/openshift-gitops-1"
{% endif %}
