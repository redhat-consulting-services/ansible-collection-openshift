---
apiVersion: config.openshift.io/v1
kind: ImageDigestMirrorSet
metadata:
  name: idms-ocp4
spec:
  imageDigestMirrors:
  - mirrors:
{% if registry.repository is not defined or registry.repository == "" %}
    - "{{ registry.url }}/openshift/release-images"
{% else %}
    - "{{ registry.url }}/{{ registry.repository }}/openshift/release-images"
{% endif %}
    source: quay.io/openshift-release-dev/ocp-release
  - mirrors:
{% if registry.repository is not defined or registry.repository == "" %}
    - "{{ registry.url }}/openshift/release"
{% else %}
    - "{{ registry.url }}/{{ registry.repository }}/openshift/release"
{% endif %}
    source: quay.io/openshift-release-dev/ocp-v4.0-art-dev
