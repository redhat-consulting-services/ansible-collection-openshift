{%- set ipv4_enabled = networking.cluster_networks | selectattr('cidr', 'ansible.utils.ipv4') | list | length > 0 %}
{%- set ipv6_enabled = networking.cluster_networks | selectattr('cidr', 'ansible.utils.ipv6') | list | length > 0 %}


apiVersion: v1beta1
kind: AgentConfig
metadata:
  name: {{ cluster_name }}
  namespace: {{ tenant_name }}

{# check if rendezvous_ip is defined, if not, use first master ip #}
{% if rendezvous_ip is defined %}
rendezvousIP: {{ rendezvous_ip }}
{% endif %}

{# check if the boot artifacts url was provided #}
{% if boot_artifacts_base_url is defined %}
bootArtifactsBaseURL: {{ boot_artifacts_base_url }}
{% endif %}

{# check if the NTP sources have been defined #}
{% if additional_ntp_sources is defined %}
additionalNTPSources: {{ additional_ntp_sources }}
{% endif %}

{# add hosts to cluster #}
hosts:
{% for agent_config_node_type, agent_config_host_value in agent_config.items() %}
  {%- if agent_config_host_value.hosts is defined and agent_config_host_value.hosts | length <= 0 %}
    {{- ('A minimum of at least one master node is required') | mandatory }}
  {%- endif %}

  {%- if agent_config_node_type not in ['master', 'worker'] %}
    {{- ('Invalid agent_config_node_type: ' ~ agent_config_node_type ~ '. Expected master or worker') | mandatory }}
  {%- endif %}

{%- for hosts in agent_config_host_value.hosts %}
  {%- set host_index = loop %}

  - role: {{ agent_config_node_type }}
    hostname: {{ hosts.hostname }}
    rootDeviceHints:
{% if hosts.root_device.serial_number is not defined and hosts.root_device.wwn is not defined %}
      deviceName: {{ hosts.root_device.name }}
{% endif %}
{% if hosts.root_device.serial_number is defined %}
      serialNumber: {{ hosts.root_device.serial_number }}
{% endif %}
{% if hosts.root_device.wwn is defined %}
      wwn: {{ hosts.root_device.wwn }}
{% endif %}
{# -------------------------------------------- #}
{# ------ Host Lookup via Interfaces MAC ------ #}
{# -------------------------------------------- #}
    interfaces:
{% for interface in hosts.interfaces %}
      - name: {{ interface.name }}
        macAddress: {{ interface.mac_address }}
{% endfor %}
{# --------------------------------- #}
{# ------ Host Network Config ------ #}
{# --------------------------------- #}
    networkConfig:
      dns-resolver:
        config:
          server:
{% for resolver in agent_config_host_value.dns_resolvers %}
            - {{ resolver }}
{% endfor %}
{# --------------------------------- #}
{# ------- Host Route Config ------- #}
{# --------------------------------- #}
      routes:
        config:
{% for route in agent_config_host_value.routes %}
          - destination: {{ route.destination }}
            next-hop-address: {{ route.gateway }}
            next-hop-interface: {{ route.interface }}
            table-id: {{ route.table_id }}
{% endfor %}
{# --------------------------------------------- #}
{# ------- Host Network Interface Config ------- #}
{# --------------------------------------------- #}
      interfaces:
{# ----------------------------------------------- #}
{# ------- Single Network Interface Config ------- #}
{# ----------------------------------------------- #}
{% for interface in hosts.interfaces %}
        - name: {{ interface.name }}
          type: ethernet
          state: up
{% if interface.mtu is defined %}
          mtu: {{ interface.mtu }}
{% endif %}
{# ------- Single Network Interface IPv4 Config ------- #}
{% if ipv4_enabled and (interface.get('ipv4_dhcp') or ((interface.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv4')) | length > 0)) %}
          ipv4:
            enabled: true
            dhcp: {{ interface.get('ipv4_dhcp', false) | lower }}
{% if (interface.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv4')) | length > 0 %}
            address:
{% for address in interface.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv4') %}
              - ip: {{ address.ip }}
                prefix-length: {{ address.subnet_length }}
{% endfor %}
{% endif %}
{% endif %}
{# ------- Single Network Interface IPv6 Config ------- #}
{% if ipv6_enabled and (interface.get('ipv6_dhcp') or ((interface.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv6')) | length > 0)) %}
          ipv6:
            enabled: true
            dhcp: {{ interface.get('ipv6_dhcp', false) | lower }}
{% if (interface.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv6')) | length > 0 %}
            address:
{% for address in interface.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv6') %}
              - ip: {{ address.ip }}
                prefix-length: {{ address.subnet_length }}
{% endfor %}
{% endif %}
{% endif %}
{# endfor interface in hosts.interfaces  #}
{% endfor%}
{# ---------------------------------------------- #}
{# -------- END SINGLE Network interface -------- #}
{# ---------------------------------------------- #}

{#- ----------------------------------------------- #}
{# -------- Bond Network Interface Config -------- #}
{# ----------------------------------------------- #}
{% for bond in agent_config_host_value.get('bonds', []) %}
{% set matching_host_bond = (hosts.get('bonds', []) | selectattr('interface', 'equalto', bond.name) | first | default({})) %}
{% set ipv4_addresses = (matching_host_bond.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv4') | list) %}
{% set ipv6_addresses = (matching_host_bond.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv6') | list) %}
        - name: {{ bond.name }}
          type: bond
          state: up
          link-aggregation:
            mode: {{ bond.mode }}
            port:
{% for interface in hosts.get('interfaces', []) | selectattr('part_of_bond', 'equalto', bond.name) %}
              - {{ interface.name }}
{% endfor %}
{% if bond.options is defined %}
            options:
{{ bond.options | to_nice_yaml(indent=14) | indent(14, true) }}
{% endif %}
{# -------- IPv4 interface Config -------- #}
{% if ipv4_enabled and (matching_host_bond.get('ipv4_dhcp') or ipv4_addresses) %}
          ipv4:
            enabled: true
            dhcp: {{ matching_host_bond.get('ipv4_dhcp', false) | lower }}
{% if ipv4_addresses %}
            address:
{% for address in ipv4_addresses %}
              - ip: {{ address.ip }}
                prefix-length: {{ address.subnet_length }}
{% endfor %}
{% endif %}
{% endif %}
{# -------- IPv6 interface Config -------- #}
{% if ipv6_enabled and (matching_host_bond.get('ipv6_dhcp') or ipv6_addresses) %}
          ipv6:
            enabled: true
            dhcp: {{ matching_host_bond.get('ipv6_dhcp', false) | lower }}
{% if ipv6_addresses %}
            address:
{% for address in ipv6_addresses %}
              - ip: {{ address.ip }}
                prefix-length: {{ address.subnet_length }}
{% endfor %}
{% endif %}
{% endif %}
{# endfor bonds #}
{% endfor %}
{# ---------------------------------------------- #}
{# --------- END BOND Network interface --------- #}
{# ---------------------------------------------- #}

{#- ----------------------------------------------- #}
{# ------- Bridge Network Interface Config ------- #}
{# ----------------------------------------------- #}
{% for bridge in agent_config_host_value.get('bridges', []) %}
{% set matching_host_bridge = (hosts.get('bridges', []) | selectattr('interface', 'equalto', bridge.name) | first | default({})) %}
{% set ipv4_addresses = (matching_host_bridge.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv4') | list) %}
{% set ipv6_addresses = (matching_host_bridge.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv6') | list) %}
        - name: {{ bridge.name }}
          state: up
          type: {{ bridge.type }}
          port:
{% for interface in bridge.get('interfaces', []) %}
            - name: {{ interface.name }}
{% endfor %}
          bridge:
            allow-extra-patch-ports: true
{% if bridge.options is defined %}
            options:
{{ bridge.options | to_nice_yaml(indent=14) | indent(14, true) }}
{% endif %}
{# -------- IPv4 interface Config -------- #}
{% if ipv4_enabled and (matching_host_bridge.get('ipv4_dhcp') or ipv4_addresses) %}
          ipv4:
            enabled: true
            dhcp: {{ matching_host_bridge.get('ipv4_dhcp', false) | lower }}
{% if ipv4_addresses %}
            address:
{% for address in ipv4_addresses %}
              - ip: {{ address.ip }}
                prefix-length: {{ address.subnet_length }}
{% endfor %}
{% endif %}
{% endif %}
{# -------- IPv6 interface Config -------- #}
{% if ipv6_enabled and (matching_host_bridge.get('ipv6_dhcp') or ipv6_addresses) %}
          ipv6:
            enabled: true
            dhcp: {{ matching_host_bridge.get('ipv6_dhcp', false) | lower }}
{% if ipv6_addresses %}
            address:
{% for address in ipv6_addresses %}
              - ip: {{ address.ip }}
                prefix-length: {{ address.subnet_length }}
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}
{# ---------------------------------------------- #}
{# -------- END BRIDGE Network interface -------- #}
{# ---------------------------------------------- #}

{#- ----------------------------------------------- #}
{# -------- VLAN Network Interface Config -------- #}
{# ----------------------------------------------- #}
{% for vlan in agent_config_host_value.get('vlans', []) %}
{% set matching_host_vlan = (hosts.get('vlans', []) | selectattr('interface', 'equalto', vlan.name) | first | default({})) %}
{% set ipv4_addresses = (matching_host_vlan.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv4') | list) %}
{% set ipv6_addresses = (matching_host_vlan.get('addresses', []) | selectattr('ip', 'ansible.utils.ipv6') | list) %}
        - name: {{ vlan.name }}
          type: vlan
          state: up
          vlan:
            base-iface: {{ vlan.base_interface }}
            id: {{ vlan.id }}
{# -------- IPv4 interface Config -------- #}
{% if ipv4_enabled and (matching_host_vlan.get('ipv4_dhcp') or ipv4_addresses) %}
          ipv4:
            enabled: true
            dhcp: {{ matching_host_vlan.get('ipv4_dhcp', false) | lower }}
{% if ipv4_addresses %}
            address:
{% for address in ipv4_addresses %}
              - ip: {{ address.ip }}
                prefix-length: {{ address.subnet_length }}
{% endfor %}
{% endif %}
{% endif %}
{# -------- IPv6 interface Config -------- #}
{% if ipv6_enabled and (matching_host_vlan.get('ipv6_dhcp') or ipv6_addresses) %}
          ipv6:
            enabled: true
            dhcp: {{ matching_host_vlan.get('ipv6_dhcp', false) | lower }}
{% if ipv6_addresses %}
            address:
{% for address in ipv6_addresses %}
              - ip: {{ address.ip }}
                prefix-length: {{ address.subnet_length }}
{% endfor %}
{% endif %}
{% endif %}

{% endfor %}
{# ---------------------------------------------- #}
{# --------- END VLAN Network interface --------- #}
{# ---------------------------------------------- #}
{# endfor hosts in agent_config_host_value.hosts #}
{% endfor %}
{# endfor agent_config_node_type, agent_config_host_value in agent_config.items() #}
{% endfor %}
